{
  "name": "netchecker",
  "title": "Netchecker",
  "description": "Check Your Net",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tauri": "cargo tauri",
    "dev": "npm run dev:sw & next dev -p 4000",
    "build": "npm run build:sw & next build",
    "start": "npx serve out -p 4000",
    "lint": "eslint src cli",
    "dev:sw": "esbuild src/sw/main.worker.ts --bundle --format=esm --target=esnext --outfile=public/sw.js --watch=forever --banner:js=\"// Generated by src/sw/main.worker.ts\"",
    "build:sw": "esbuild src/sw/main.worker.ts --bundle --format=esm --target=esnext --outfile=public/sw.js --minify --banner:js=\"// Generated by src/sw/main.worker.ts\"",
    "dev:injection": "esbuild src-tauri/src/inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/src/inject.js --watch=forever --banner:js=\"// Generated by src-tauri/src/inject.ts\"",
    "build:injection": "esbuild src-tauri/src/inject.ts --bundle --format=esm --target=esnext --outfile=src-tauri/src/inject.js --minify --banner:js=\"// Generated by src-tauri/src/inject.ts\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "leaflet": "^1.9.4",
    "next": "16.2.0",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.27.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "type": "module"
}
